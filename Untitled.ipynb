    "import numpy as np\n",
    "from uv_tutorial_lib import hello\n",
    "\n",
    "def add(x: list[float], y: list[float]) -> float:\n",
    "    return np.sum(x) + np.sum(y)\n",
    "\n",
    "def main():\n",
    "    print(\"Hello from uv-tutorial-app!\")\n",
    "    print(f\"The result of add is: {add([1, 2], [3, 4]) = }\")\n",
    "    print(hello())\n",
    "\n",
    "main()"
